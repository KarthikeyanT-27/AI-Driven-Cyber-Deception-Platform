{
  "index_patterns": ["sessions"],
  "template": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 0
    },
    "mappings": {
      "properties": {
        "session_id":          { "type": "keyword" },
        "honeypot":             { "type": "keyword" },
        "src_ip":               { "type": "ip", "ignore_malformed": true },
        "start_time":           { "type": "date" },
        "last_seen":            { "type": "date" },
        "total_event_count":    { "type": "integer" },
        "attack_event_count":   { "type": "integer" },
        "infra_event_count":    { "type": "integer" },
        "stage":                { "type": "keyword" },
        "risk_score":           { "type": "integer" },
        "decision":             { "type": "keyword" },
        "confidence":           { "type": "float" },
        "timeline": {
          "type": "nested",
          "properties": {
            "timestamp": { "type": "date" },
            "summary":   { "type": "text" }
          }
        },
        "mitre_techniques": {
          "type": "nested",
          "properties": {
            "technique_id":   { "type": "keyword" },
            "technique_name": { "type": "keyword" },
            "tactic":         { "type": "keyword" },
            "matched_on":     { "type": "keyword" }
          }
        },
        "iocs": {
          "type": "nested",
          "properties": {
            "ip":         { "type": "ip", "ignore_malformed": true },
            "domain":     { "type": "keyword" },
            "url":        { "type": "keyword" },
            "hash":       { "type": "keyword" },
            "hash_type":  { "type": "keyword" },
            "risk_score": { "type": "integer" },
            "tags":       { "type": "keyword" }
          }
        }
      }
    }
  }
}
