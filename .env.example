# ==============================================================================
# AI-Driven Adaptive Cyber Deception Platform — Environment Configuration
# Copy this file to ".env" and fill in real values. Never commit ".env".
# ==============================================================================

# ---------- Elastic Stack ----------
ELASTIC_VERSION=8.13.4
ELASTIC_PASSWORD=changeme_elastic_password
ELASTICSEARCH_HOST=http://elasticsearch:9200
KIBANA_PASSWORD=changeme_kibana_password
xpack_security_enabled=false

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis_password

# ---------- ChromaDB ----------
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION=attack_memory

# ---------- LLM Backend (swappable: groq | openai | ollama) ----------
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_URL=https://api.openai.com/v1/chat/completions

OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3

# ---------- Escalation Engine ----------
ESCALATION_HOST=0.0.0.0
ESCALATION_PORT=8001
ESCALATE_THRESHOLD=70
USE_PRETRAINED_NLP=true
DISTILBERT_MODEL=distilbert-base-uncased-finetuned-sst-2-english

# ---------- RAG Proxy ----------
RAG_PROXY_PORT=8002

# ---------- Telemetry ----------
TELEMETRY_PORT=8003
TELEMETRY_POLL_INTERVAL_SECONDS=10

# ---------- HoneyTrap ----------
HONEYTRAP_PORT=8004
HONEYTOKEN_REFRESH_HOURS=24

# ---------- SOC Chatbot Dashboard ----------
DASHBOARD_PORT=8501

# ---------- Cowrie ----------
COWRIE_SSH_PORT=2222
COWRIE_TELNET_PORT=2223

# ---------- Dionaea ----------
DIONAEA_FTP_PORT=2121
DIONAEA_HTTP_PORT=8080
DIONAEA_SMB_PORT=4445

# ---------- Elastichoney (fake Elasticsearch honeypot) ----------
ELASTICHONEY_PORT=9201
